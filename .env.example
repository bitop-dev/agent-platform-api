# Server
PORT=8080
HOST=0.0.0.0
BASE_URL=http://localhost:8080

# Database (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite://data/platform.db
# DATABASE_URL=postgres://user:pass@localhost:5432/agent_platform?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-real-secret
JWT_EXPIRY_MINUTES=60

# Encryption key for API keys at rest (32-byte hex)
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OAuth (optional — enables social login)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Defaults for new agents
DEFAULT_MODEL=gpt-4o
DEFAULT_PROVIDER=openai
